generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Skill {
  id          Int      @id @default(autoincrement())
  profileId   Int
  name        String
  level       Int
  category    String
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, category, sortOrder])
  @@index([category, sortOrder])
  @@index([isPublished])
}

model Experience {
  id             Int       @id @default(autoincrement())
  profileId      Int
  title          String
  company        String
  description    String
  startDate      DateTime
  endDate        DateTime?
  location       String?
  employmentType String?
  image          String?
  isCurrent      Boolean   @default(false)
  sortOrder      Int       @default(0)
  isPublished    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  profile        Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isCurrent, sortOrder])
  @@index([isCurrent, sortOrder])
  @@index([isPublished])
}

model Certificate {
  id           Int      @id @default(autoincrement())
  profileId    Int
  title        String
  issuer       String
  image        String
  link         String
  category     String
  issuedAt     DateTime?
  expiresAt    DateTime?
  credentialId String?
  sortOrder    Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, category, sortOrder])
  @@index([category, sortOrder])
  @@index([isPublished])
}

model Portfolio {
  id          Int      @id @default(autoincrement())
  profileId   Int
  title       String
  slug        String
  description String
  descriptions Json?
  tech        Json
  image       String
  badge       String
  repoUrl     String?
  demoUrl     String?
  sortOrder   Int      @default(0)
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, slug])
  @@index([profileId, isPublished, sortOrder])
  @@index([isPublished, sortOrder])
  @@index([isFeatured])
}

model SiteContent {
  id        Int      @id @default(autoincrement())
  profileId Int      @unique
  hero      Json
  about     Json
  contact   Json?
  seo       Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SiteConfig {
  id         Int      @id @default(autoincrement())
  profileId  Int      @unique
  logoText   String?
  logoImage  String?
  navigation Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AdminSettings {
  id           Int      @id @default(1)
  integrations Json
  security     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminAuditEvent {
  id              Int      @id @default(autoincrement())
  actorUserId     String?
  targetProfileId Int?
  action          String
  targetType      String?
  targetId        String?
  metadata        Json?
  createdAt       DateTime @default(now())
  actorUser       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetProfile   Profile? @relation("AuditTargetProfile", fields: [targetProfileId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([createdAt])
}

enum PhotoSourceType {
  upload
  gdrive
}

enum UserRole {
  super_admin
  admin
  editor
  viewer
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole          @default(viewer)
  isActive      Boolean           @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  auditEvents   AdminAuditEvent[] @relation("AuditActor")
}

model Profile {
  id          Int               @id @default(autoincrement())
  userId      String            @unique
  slug        String            @unique
  displayName String
  isPublic    Boolean           @default(true)
  isPrimary   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills      Skill[]
  experiences Experience[]
  certificates Certificate[]
  portfolios  Portfolio[]
  siteContent SiteContent?
  siteConfig  SiteConfig?
  albums      Album[]
  auditEvents AdminAuditEvent[] @relation("AuditTargetProfile")

  @@index([isPublic])
  @@index([isPrimary])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Album {
  id           Int         @id @default(autoincrement())
  profileId    Int
  name         String
  slug         String
  description  String?
  coverPhotoId Int?        @unique
  isPublished  Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  photos       AlbumPhoto[]
  coverPhoto   AlbumPhoto? @relation("AlbumCoverPhoto", fields: [coverPhotoId], references: [id], onDelete: SetNull)

  @@unique([profileId, slug])
  @@index([profileId, isPublished, createdAt])
  @@index([isPublished, createdAt])
}

model AlbumPhoto {
  id               Int             @id @default(autoincrement())
  albumId          Int
  imageUrl         String
  cloudinaryPublicId String?
  contentHash      String?
  originalFilename String?
  mimeType         String?
  fileSizeBytes    Int?
  caption          String?
  dateTaken        DateTime?
  uploadedAt       DateTime        @default(now())
  sortOrder        Int             @default(0)
  sourceType       PhotoSourceType @default(upload)
  sourceId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  album            Album           @relation(fields: [albumId], references: [id], onDelete: Cascade)
  coverForAlbum    Album?          @relation("AlbumCoverPhoto")

  @@index([albumId, sortOrder])
  @@index([albumId, dateTaken])
  @@index([albumId, uploadedAt])
  @@index([albumId, sourceType, sourceId])
  @@unique([albumId, contentHash])
}


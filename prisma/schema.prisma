generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Skill {
  id          Int      @id @default(autoincrement())
  name        String
  level       Int
  category    String
  description String?
  image       String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, sortOrder])
  @@index([isPublished])
}

model Experience {
  id          Int       @id @default(autoincrement())
  title       String
  company     String
  description String
  startDate   DateTime
  endDate     DateTime?
  location    String?
  employmentType String?
  image       String?
  isCurrent   Boolean   @default(false)
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isCurrent, sortOrder])
  @@index([isPublished])
}

model Certificate {
  id          Int      @id @default(autoincrement())
  title       String
  issuer      String
  image       String
  link        String
  category    String
  issuedAt    DateTime?
  expiresAt   DateTime?
  credentialId String?
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, sortOrder])
  @@index([isPublished])
}

model Portfolio {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String
  descriptions Json?
  tech        Json
  image       String
  badge       String
  repoUrl     String?
  demoUrl     String?
  sortOrder   Int      @default(0)
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, sortOrder])
  @@index([isFeatured])
}

model SiteContent {
  id        Int      @id @default(1)
  hero      Json
  about     Json
  contact   Json?
  seo       Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id        Int      @id @default(1)
  logoText  String?
  logoImage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PhotoSourceType {
  upload
  gdrive
}

model Album {
  id           Int         @id @default(autoincrement())
  name         String
  slug         String      @unique
  description  String?
  coverPhotoId Int?        @unique
  isPublished  Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  photos       AlbumPhoto[]
  coverPhoto   AlbumPhoto? @relation("AlbumCoverPhoto", fields: [coverPhotoId], references: [id], onDelete: SetNull)

  @@index([isPublished, createdAt])
}

model AlbumPhoto {
  id               Int             @id @default(autoincrement())
  albumId          Int
  imageUrl         String
  cloudinaryPublicId String?
  caption          String?
  dateTaken        DateTime?
  uploadedAt       DateTime        @default(now())
  sortOrder        Int             @default(0)
  sourceType       PhotoSourceType @default(upload)
  sourceId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  album            Album           @relation(fields: [albumId], references: [id], onDelete: Cascade)
  coverForAlbum    Album?          @relation("AlbumCoverPhoto")

  @@index([albumId, sortOrder])
  @@index([albumId, dateTaken])
  @@index([albumId, uploadedAt])
}

